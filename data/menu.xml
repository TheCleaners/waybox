<?xml version="1.0" encoding="UTF-8"?>

<openbox_menu xmlns="http://openbox.org/3.4/menu">

<!--
  Default Waybox root menu.

  Parsed natively by the compositor for the built-in root menu (the ShowMenu
  action, bound to a Root right-click in rc.xml), and also by the `waybox-menu`
  script (a rofi script mode). Menu items use <execute> (like rc.xml); <command>
  works too. Commands are run without a shell, so prefer literal program names;
  constructs like pipes, $VARS or && will not be expanded here.

  Copy this to $XDG_CONFIG_HOME/waybox/menu.xml (usually
  ~/.config/waybox/menu.xml) and edit it to taste.
-->

<menu id="root-menu" label="Waybox">
  <item label="Terminal">
    <action name="Execute">
      <execute>foot</execute>
    </action>
  </item>
  <item label="Run">
    <action name="Execute">
      <execute>rofi -show drun</execute>
    </action>
  </item>
  <item label="Web Browser">
    <action name="Execute">
      <execute>xdg-open https://</execute>
    </action>
  </item>
  <item label="Files">
    <action name="Execute">
      <execute>xdg-open .</execute>
    </action>
  </item>

  <menu id="waybox-menu" label="Waybox">
    <item label="Reconfigure">
      <action name="Reconfigure"/>
    </item>
    <item label="Exit">
      <action name="Exit"/>
    </item>
  </menu>
</menu>

</openbox_menu>
